{
  "cli": {
    "version": ">= 16.17.4",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.18.0",
      "env": {
        "npm_config_legacy_peer_deps": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "node": "20.18.0",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://workouttracker-production-601f.up.railway.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "20.18.0"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "grifvondeben31@gmail.com",
        "language": "en-US"
      }
    }
  }
}
