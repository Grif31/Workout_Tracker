{
  "name": "workout-tracker-native",
  "license": "0BSD",
  "version": "1.0.0",
  "main": "index.js",
  "expo": {
    "install": {
      "exclude": []
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "modulePaths": [
      "<rootDir>"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-gifted-charts|react-native-draggable-flatlist|react-native-reanimated)"
    ],
    "moduleNameMapper": {
      "^utils/units$": "<rootDir>/__mocks__/utils/units.ts"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/testUtils\\.tsx$"
    ]
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@expo/react-native-action-sheet": "^4.1.1",
    "@expo/vector-icons": "^15.0.2",
    "@mapbox/polyline": "^1.2.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-community/netinfo": "^11.5.2",
    "@react-native-picker/picker": "^2.11.4",
    "@react-navigation/bottom-tabs": "^7.4.7",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.25",
    "axios": "^1.11.0",
    "babel-preset-expo": "~55.0.8",
    "expo": "~55.0.26",
    "expo-apple-authentication": "~55.0.13",
    "expo-asset": "~55.0.17",
    "expo-auth-session": "~55.0.16",
    "expo-blur": "^55.0.14",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-dev-client": "~55.0.35",
    "expo-file-system": "~55.0.22",
    "expo-font": "~55.0.8",
    "expo-haptics": "^55.0.14",
    "expo-image-picker": "~55.0.20",
    "expo-linear-gradient": "~55.0.14",
    "expo-location": "~55.1.10",
    "expo-modules-core": "~55.0.25",
    "expo-notifications": "~55.0.23",
    "expo-sharing": "~55.0.20",
    "expo-status-bar": "~55.0.6",
    "expo-web-browser": "~55.0.16",
    "jest": "~29.7.0",
    "react": "^19.2.0",
    "react-native": "^0.83.6",
    "react-native-body-highlighter": "^3.2.0",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-dotenv": "^3.4.11",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-health": "^1.13.0",
    "react-native-health-connect": "^3.5.3",
    "react-native-maps": "^1.27.2",
    "react-native-purchases": "^10.2.2",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-vector-icons": "^10.3.0",
    "react-native-view-shot": "4.0.3",
    "react-native-worklets": "^0.7.4"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.0",
    "@types/mapbox__polyline": "^1.0.5",
    "@types/react": "^19.1.10",
    "@types/react-native-vector-icons": "^6.4.18",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.18",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.9.2"
  },
  "private": true
}
