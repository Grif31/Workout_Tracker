# Copy this file to .env and fill in your values

# Local development (SQLite)
DATABASE_URL=sqlite:///workout_tracker.db

# Production (PostgreSQL) - replace with your actual connection string
# DATABASE_URL=postgresql://user:password@host:5432/workout_tracker

JWT_SECRET_KEY=your-secret-key-here

# CORS — comma-separated list of allowed origins (browsers only; mobile app is unaffected).
# Omit or set to * in development. In production, list your real domain(s).
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
